# Runtime mode. Seed data is the production-safe default.
USE_SUPABASE=false
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Supabase database pass. Never expose the secret key to the browser.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Optional delivery pass. Without these values the lead API validates and logs a redacted synthetic event.
RESEND_API_KEY=
RESEND_FROM_EMAIL=InvestorStack <onboarding@resend.dev>
LEAD_NOTIFICATION_EMAIL=
